# Olist E-Commerce Pipeline Configuration
# Copy this file to '.env' and modify the values to match your local setup.

# Database Connection Settings
OLIST_DB_HOST=localhost
OLIST_DB_PORT=5432
OLIST_DB_NAME=olist_ecommerce
OLIST_DB_USER=postgres

# Database Password
OLIST_DB_PASSWORD=your_password_here

# Dataset Directory Path
# Path to the folder containing raw Kaggle CSV files
OLIST_DATA_DIR=../data
